# GBA Go Operations Copilot demo configuration.
# Copy this file to .env for local development.

APP_ENV=demo
SAMPLE_DATA_DIR=sample_data
COPILOT_AUDIT_LOG=demo_runtime/audit_log.jsonl

# Default local mode keeps the demo runnable without sending data to a model.
# Set COPILOT_LLM_MODE=openai and provide OPENAI_API_KEY to use the authenticated OpenAI path.
# Replace OPENAI_MODEL with the model available in your OpenAI account.
COPILOT_LLM_MODE=local
OPENAI_API_KEY=
OPENAI_MODEL=your_model_name
OPENAI_TIMEOUT_SECONDS=20
